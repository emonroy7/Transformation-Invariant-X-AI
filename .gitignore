# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# ---- Virtual environments ----
.venv/
venv/
env/
ENV/
.conda/

# ---- Jupyter ----
.ipynb_checkpoints/
notebooks/**/*-checkpoint.ipynb

# ---- ML / experiment artifacts ----
# Datasets are not versioned here (see data/README.md)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Model weights / checkpoints
*.h5
*.hdf5
*.ckpt
*.pt
*.pth
*.onnx
*.pb
checkpoints/
weights/

# Generated results (keep the folders, ignore the contents)
results/figures/*
results/tables/*
!results/figures/.gitkeep
!results/tables/.gitkeep
*.npy
*.npz

# ---- Logs / caches ----
*.log
logs/
runs/
wandb/
.cache/

# ---- OS / editor ----
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
